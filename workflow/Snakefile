from pathlib import Path
import itertools


WORKFLOW = Path("workflow").resolve()
CONFIG = Path("config").resolve()
RESULTS = Path("/scratch/project/bug_seq_scratch/qc_bench/results").resolve()
DATA = Path("/scratch/user/s4897040/biox7021/data").resolve()
FIGURES = RESULTS / "figures"
TABLES = RESULTS / "tables"
LOGS = Path("logs/rules").resolve()

RULES = WORKFLOW / "rules"
ENVS = WORKFLOW / "envs"
BENCHMARK = RESULTS / "benchmark"

configfile: CONFIG / "config.yaml"
pepfile: str(CONFIG / "pep/project_config.yaml")
pepschema: str(CONFIG / "pep/pep_schema.yaml")

SAMPLES = pep.sample_table["sample_name"]
TRIMMING = config["trimming"] + ["untrimmed"]
FILTERING = config["filtering"]
DEPTHS = config["depth"]
MODELS = config["model"]
REPEAT = config["repeat"]

KITS = pep.sample_table["sequencing_kits"]

PORECHOP_ABI_SETTINGS = ["nocheck", "discard", "split"]
BARBELL_KIT_SETTINGS = ["default", "max"]

# Reorganise the target file uusing expand function https://snakemake.readthedocs.io/en/stable/snakefiles/rules.html#the-expand-function
EVAL_TRIMMERS = []
for t in TRIMMING:
    if t == "porechop_abi":
        EVAL_TRIMMERS.extend([f"{t}_{s}" for s in PORECHOP_ABI_SETTINGS])
    elif t == "barbell":
        EVAL_TRIMMERS.extend([f"{t}_{s}" for s in BARBELL_KIT_SETTINGS])
    else:
        EVAL_TRIMMERS.append(t)

QENDS_TRIMMERS = [t for t in EVAL_TRIMMERS if "porechop_abi" not in t or t == "porechop_abi_nocheck"]

pr_files = expand(
    RESULTS / "assess/call/{trimmer}/{depth}x/{sample}/{model}/{sample}.precision-recall.tsv",
    trimmer=EVAL_TRIMMERS, depth=DEPTHS, sample=SAMPLES, model=MODELS
)

contam_report_files = expand(
    RESULTS / "assess/assembly/contaminant/{trimmer}/{depth}x/{sample}/{model}/{sample}.{trimmer}.contaminants.tsv",
    trimmer=EVAL_TRIMMERS, depth=DEPTHS, sample=SAMPLES, model=MODELS
)

target_files = expand(
    [
        RESULTS / "assess/call/{trimmer}/{depth}x/{sample}/{model}/{sample}.precision-recall-summary.tsv",
        RESULTS / "assess/assembly/quast/{trimmer}/{depth}x/{sample}/{model}/{sample}.{trimmer}.report.tsv",
        RESULTS / "assess/assembly/contaminant/{trimmer}/{depth}x/{sample}/{model}/{sample}.{trimmer}.contaminants.tsv"
    ],
    trimmer=EVAL_TRIMMERS, depth=DEPTHS, sample=SAMPLES, model=MODELS
)

# qends_files = expand(
