PORECHOP_ABI_SETTINGS = ["nocheck", "discard", "split"]
BARBELL_KIT_SETTINGS = ["default", "max"]
FASTPLONG_SEQKIT_SETTINGS = ["100", "1000"]
FILTLONG_SETTINGS = ["meanq", "len", "default"]
CHOPPER_SETTINGS = ["trim100", "trim1000", "extract100", "extract1000"]

EVAL_TOOLS = []
for t in TOOLS:
	if t == "fastplong":
		EVAL_TOOLS.extend([f"{t}_{s}" for s in FASTPLONG_SEQKIT_SETTINGS])
	elif t == "seqkit":
		EVAL_TOOLS.extend([f"{t}_{s}" for s in FASTPLONG_SEQKIT_SETTINGS])
	elif t == "filtlong":
		EVAL_TOOLS.extend([f"{t}_{s}" for s in FILTLONG_SETTINGS])
	elif t == "chopper":
		EVAL_TOOLS.extend([f"{t}_{s}" for s in CHOPPER_SETTINGS])
	else: # untrimmed
		EVAL_TOOLS.append(t)


pr_files = expand(
    RESULTS / "assess/call/{tool}/{depth}x/{model}/{sample}.precision-recall.tsv",
    tool=EVAL_TOOLS, depth=DEPTHS, sample=SAMPLES, model=MODELS
)

contam_report_files = expand(
