EVAL_TOOLS = []
for t in QUALITY:
	if t == "fastplong":
		EVAL_TOOLS.extend([f"{t}_{s}" for s in FASTPLONG_SEQKIT_SETTINGS])
	elif t == "seqkit":
		EVAL_TOOLS.extend([f"{t}_{s}" for s in FASTPLONG_SEQKIT_SETTINGS])
	elif t == "filtlong":
		EVAL_TOOLS.extend([f"{t}_{s}" for s in FILTLONG_SETTINGS])
	elif t == "chopper":
		EVAL_TOOLS.extend([f"{t}_{s}" for s in CHOPPER_SETTINGS])
	else: # untrimmed
		EVAL_TOOLS.append(t)


pr_files = expand(
    RESULTS / "assess/call/{tool}/{depth}x/{sample}/{model}/{sample}.precision-recall.tsv",
    tool=EVAL_TOOLS, depth=DEPTHS, sample=SAMPLES, model=MODELS
)

contam_report_files = expand(
    RESULTS / "assess/assembly/contaminant/{tool}/{depth}x/{sample}/{model}/{sample}.{tool}.contaminants.tsv",
    tool=EVAL_TOOLS, depth=DEPTHS, sample=SAMPLES, model=MODELS
)

target_files = expand(
    [
        RESULTS / "assess/call/{tool}/{depth}x/{sample}/{model}/{sample}.precision-recall-summary.tsv",
        RESULTS / "assess/assembly/quast/{tool}/{depth}x/{sample}/{model}/{sample}.{tool}.report.tsv",
        RESULTS / "assess/assembly/contaminant/{tool}/{depth}x/{sample}/{model}/{sample}.{tool}.contaminants.tsv"
    ],
    tool=EVAL_TOOLS, depth=DEPTHS, sample=SAMPLES, model=MODELS
)

