COMBINATIONS = []
for tool in EVAL_TOOLS:
	if tool == "fastplong":
		tool = tool + "-" + "all"
		COMBINATIONS.append(tool)
	else:
		for trimmer in EVAL_TRIMMERS:
			combo = tool + "-" + trimmer
			COMBINATIONS.append(combo)

